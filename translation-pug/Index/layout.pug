include ../bodyMatter.pug
include ./dbs/index.pug

mixin linkContainer(href)
  div(class="flex flex-row items-center justify-between w-full font-bold")
    a(
      href=href
      class="cursor-pointer hover:brightness-120 hover:pl-2 grow p-1 m-1"
    )&attributes(attributes)
      block

meta(charset="UTF-8")
meta(name="viewport", content="width=device-width,initial-scale=1")
title
  +renderKey("documentTitle")
link(rel="stylesheet", href="/src/index.css")
#root
  a#menu-link(href="../../index.html") &uarr;
  div(class="max-w-[900px] pl-1 pt-1")
    header(class="border-b-1 border-black text-center bg-green-100")
      h1(class="text-2xl font-bold")
        +renderKey("bookTitle")
      h2(class="text-xl mb-1") 
        +renderKey("bookSubtitle")
      p 
        +renderKey("bookAbout")
      p 
        +renderKey("bookPublisherInfo")
    b
      +renderKey("chapterSelection")
    br
    #chapter-select(class="flex flex-col flex-wrap border-1 border-dashed border-black mb-1")
      +linkContainer("./preface.html")(class="bg-purple-800 text-white")
        +renderKey("prefaceTitle")
      +linkContainer("./advisoryCommittee.html")(class="bg-purple-800 text-white")
        +renderKey("advisoryCommittee")
      +linkContainer("./prefaceOfFirstEdition.html")(class="bg-purple-800 text-white")
        +renderKey("preface1stEd")
      +linkContainer("./grammarNotes.html")(class="bg-purple-800 text-white")
        +renderKey("abbrevAndGrammarTitle")
      +linkContainer("./chapter1.html")(class="bg-blue-950 text-white")
        +renderKey("Chapter1")
      +linkContainer("./chapter2.html")(class="bg-orange-600 text-white")
        +renderKey("Chapter2")
      +linkContainer("./chapter3.html")(class="bg-lime-300 text-black")
        +renderKey("Chapter3")
      +linkContainer("./chapter4.html")(class="bg-yellow-300 text-black")
        +renderKey("Chapter4")
      +linkContainer("./chapter5.html")(class="bg-red-600 text-white")
        +renderKey("Chapter5")
      +linkContainer("./chapter6.html")(class="bg-sky-600 text-white")
        +renderKey("Chapter6")
      +linkContainer("./chapter7.html")(class="bg-pink-600 text-white")
        +renderKey("Chapter7")
      +linkContainer("./chapter8.html")(class="bg-green-700 text-white")
        +renderKey("Chapter8")
      +linkContainer("./chapter9.html")(class="bg-fuchsia-900 text-white")
        +renderKey("Chapter9")
      +linkContainer("./chapter10.html")(class="bg-amber-400 text-black")
        +renderKey("Chapter10")
      +linkContainer("./chapter11.html")(class="bg-blue-950 text-white")
        +renderKey("Chapter11")
      +linkContainer("./tableOfOptions.html")(class="bg-purple-800 text-white")
        +renderKey("tableOfOptions")
      +linkContainer("./bookIndex.html")(class="bg-purple-800 text-white")
        +renderKey("index")

    footer(class="fixed bottom-0 w-[100%] p-2 border-y-1 border-black bg-white")
      +renderKey('footerDisclaimer', { getFromCommon: true })