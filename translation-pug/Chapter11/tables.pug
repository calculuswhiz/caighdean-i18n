mixin lineBreakExample(exampleKey)
  if docLang === "GA"
    li: +renderKey(exampleKey)
  else
    li
      +renderKey(exampleKey, { getFromGa: true })
      | #[br]
      | (#[+renderKey(exampleKey)])

mixin Table11F
  +markedTable(11, "F", "Table11F-caption")
    +autoColgroup([1, 3])
    thead
      tr
        th: +renderKey("Table11F-header1")
        th: +renderKey("Table11F-header2")
    tbody
      tr
        th cad
        td: ul
          +lineBreakExample("Table11F-cad-example1")
          +lineBreakExample("Table11F-cad-example2")
      tr
        th cathain
        td: ul
          +lineBreakExample("Table11F-cathain-example")
      tr
        th cá fhad, cén fhad*
        td: ul
          +lineBreakExample("Table11F-fhad-example1")
          +lineBreakExample("Table11F-fhad-example2")
      tr
        th cá mhéad, cé mhéad, cén méid
        td: ul
          +lineBreakExample("Table11F-mhéad-example1")
          +lineBreakExample("Table11F-mhéad-example2")
          +lineBreakExample("Table11F-mhéad-example3")
      tr
        th cé
        td: ul
          +lineBreakExample("Table11F-cé-example1")
      tr
        th cé acu, cibé acu
        td: ul
          +lineBreakExample("Table11F-acu-example1")
          +lineBreakExample("Table11F-acu-example2")
          +lineBreakExample("Table11F-acu-example3")
      tr
        th céard
        td: ul
          +lineBreakExample("Table11F-céard-example1")
      tr
        th cá huair, cén uair
        td: ul
          +lineBreakExample("Table11F-uair-example1")
          +lineBreakExample("Table11F-uair-example2")
      tr
        th chomh + #[+renderKey("Table11F-dobhriathar-ama")] + is
        td: ul
          +lineBreakExample("Table11F-chomh-example1")
          +lineBreakExample("Table11F-chomh-example2")
      tr
        th conas
        td: ul
          +lineBreakExample("Table11F-conas-example1")
      tr
        th cad é mar, mar (#[i: +renderKey("Table11F-cónasc")])
        td: ul
          +lineBreakExample("Table11F-mar-example1")
          +lineBreakExample("Table11F-mar-example2")
      tr
        th nuair
        td: ul
          +lineBreakExample("Table11F-nuair-example1")

