mixin arrowSampleBox(samplePrefix, sampleCount, startAt = 1)
  table.samplebox(class="my-1")
    tbody
      each row in range(startAt, startAt + sampleCount - 1)
        tr
          if docLang === "GA"
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              +renderKey(`${samplePrefix}${row}a`)
          else
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              +renderKey(`${samplePrefix}${row}a`, { getFromGa: true })
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              +renderKey(`${samplePrefix}${row}a`)
        tr
          if docLang === "GA"
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              | &rarr;&nbsp;
              +renderKey(`${samplePrefix}${row}b`)
          else
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              | &rarr;&nbsp;
              +renderKey(`${samplePrefix}${row}b`, { getFromGa: true })
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              | &rarr;&nbsp;
              +renderKey(`${samplePrefix}${row}b`)

mixin Table11A
  +markedTable(11, "A", "Table11A-caption")
    thead
      tr
        th(colspan="2" class="text-xl py-2")
          +renderKey("Table11A-header")
      tr
        th: +renderKey("Table11A-col1")
        th: +renderKey("Table11A-col2")
    tbody
