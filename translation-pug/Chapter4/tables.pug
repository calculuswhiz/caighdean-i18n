mixin Table4D
  +markedTable(4, "D", "Table4D-caption")
    thead
      tr
        th(colspan=4 class="text-xl"): +renderKey("Table4D-title")
      tr
        th: +renderKey("Table4D-col1")
        th: +renderKey("Table4D-col2")
        th: +renderKey("Table4D-col3")
        th: +renderKey("Table4D-col4")
    tbody
      tr
        th(class="bg-stone-300" rowspan=3): +renderKey("Table4D-case1")
        td an fear #[b beag]
        td an fear #[b misniúil]
        td an cóta #[b buí]
      tr
        td an peileadóir #[b clúiteach]
        td an duine #[b cóir]
        td an garda #[b cróga]
      tr(class="black-bottom-divider")
        td an buachaill #[b ciúin]
        td an t&#x2011;óstóir #[b flaithiúil]
        td an duine #[b cuí]

      tr
        th(class="bg-stone-300" rowspan=3): +renderKey("Table4D-case2")
        td a fhir #[b bhig]
        td a fhir #[b mhisniúil]
        td a gharda #[b chróga]
      tr
        td a pheileadóir #[b chlúiteach]
        td a dhuine #[b chóir]
        td a dhuine #[b chuí]
      tr(class="black-bottom-divider")
        td a bhuachaill #[b chiúin]
        td a t&#x2011;óstóir #[b fhlaithiúil]
        td a fhear #[b chliste]

      tr
        th(class="bg-stone-300" rowspan=3)
          | #[+renderKey("Table4D-case3")]*
        td ag an bhfear #[b beag]
        td don fhear #[b misniúil]
        td ar an gcóta #[b buí]
      tr
        td don pheileadóir #[b clúiteach]
        td chuig an duine #[b cóir]
        td ag an ngarda #[b cróga]
      tr(class="black-bottom-divider")
        td leis an mbuachaill #[b ciúin]
        td ón óstóir #[b flaithiúil]
        td leis an duine #[b cuí]

      tr
        th(class="bg-stone-300" rowspan=3): +renderKey("Table4D-case4")
        td caipín an fhir #[b bhig]
        td eachtra an fhir #[b mhisniúil]
        td úinéir an chóta #[b bhuí]
      tr
        td ainm an pheileadóra #[b chlúitigh]
        td clann an duine #[b chóir]
        td thar ceann an duine #[b chuí]
      tr
        td rang an bhuachalla #[b chiúin]
        td comhairle an óstóra #[b fhlaithiúil]
        td guth an gharda #[b chróga]

