mixin Table4A
  +markedTable(4, "A", "Table4A-caption")
    colgroup
      col(class="w-1/5")
      col(class="w-2/5")
      col(class="w-2/5")
    thead
      tr
        th: +renderKey("Table4A-col1")
        th: +renderKey("Table4A-col2")
        th: +renderKey("Table4A-col3")
    tbody
      tr
        th: +renderKey("Table4A-row1")
        td
          p: i: +renderKey("no-lenition")
          p an fear #[b beag]
        td
          p: i: +renderKey("séimhiú", { getFromCommon: true })
          p an bhean #[b bheag]
      tr
        th: +renderKey("Table4A-row2")
        td
          p: i: +renderKey("séimhiú", { getFromCommon: true })
          p a fhir #[b bhig]
        td
          p: i: +renderKey("séimhiú", { getFromCommon: true })
          p a bhean #[b bheag]
      tr
        th: +renderKey("Table4A-row3")
        td
          p: i: +renderKey("no-lenition")
          p ar an bhfear #[b beag]
        td
          p: i: +renderKey("séimhiú", { getFromCommon: true })
          p ar an mbean #[b bheag]
      tr
        th: +renderKey("Table4A-row4")
        td
          p: i: +renderKey("séimhiú", { getFromCommon: true })
          p clann an fhir #[b bhig]
        td
          p: i: +renderKey("no-lenition")
          p clann na mná #[b bige]

