        | Only one form is used for the following adjectives: #[i dócha], #[i dóichí] #[+tl likely]; #[i dona], #[i donacht] #[+tl bad]; #[i furasta], #[i fusacht] #[+tl easy]; #[i gearr], #[i giorracht] #[+tl short]; and for these irregular forms: #[i beag], #[i laghad] #[+tl small]; #[i fada], #[i fad] #[+tl long]; #[i iomaí], #[i liacht] #[+tl many]; #[i maith], #[i feabhas] #[+tl good]; #[i mór], #[i méad/méid] #[+tl big]; #[i olc], #[i olcas] #[+tl bad]; #[i tiubh], #[i tiús] #[+tl thick].
      when "4-8-3-c-p"
        | #[i méid] is used instead of #[i méad] in certain contexts, e.g., #[i dá mhéad airgead a bhí aici] but #[i a mhéid is indéanta le réasún]; #[i a mhéid is gá].
      when "4-8-3-c-p-sample1"
