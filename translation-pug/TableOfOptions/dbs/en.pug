      when "Choice1B"
        | The Central System and the Lenition System
      when "CrossRef1B"
        | #[+link("./chapter1.html#sec_1_4", "1.4")] and #[+link("./chapter1.html#sec_1_7", "1.7")]
      when "ch3-link"
        | #[+link("./chapter3.html", "3")]
      when "Choice3"
