include ../../tlMatter.pug
if docLang === "EN"
  mixin tl(tlText)
    if tlText != null
      +inlineTl("EN", tlText)
    else
      +inlineTl("EN")
        block
    
  mixin tlDb(key)
    case key
      when "TableOfOptionsTitle"
        | Table of Options
      when "p1"
        | Several options are permitted in the Official Standard. As a reference aid, those options are shown in the table below.
      when "TableCaption"
        | Table of Options
      when "Col1"
        | Chapter
      when "Col2"
        | Option
      when "Col3"
        | Cross Reference
      when "ch1-link"
        | #[+link("./chapter1.html", "1")]
      when "Choice1A"
        | The Dative Case
      when "CrossRef1A"
