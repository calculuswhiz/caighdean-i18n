      when "CrossRef3"
        | #[+link("./chapter3.html#sec_3_2", "3.2")]
      when "ch5-link"
        | #[+link("./chapter5.html", "5")]
      when "Choice5A"
        | #[i Muid] and the Analytic Verb Form
      when "CrossRef5A"
