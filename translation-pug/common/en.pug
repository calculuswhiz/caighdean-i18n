if docLang === 'EN'
  mixin commonTlDb(key)
    case key
      when "tableOfContents"
        | Table of Contents
      when "showHide"
        | Show/Hide
      when "menu"
        | Menu
      //- The Irish text will not be translated as it is a disclaimer about the translation itself.
      when "footerDisclaimer"
        | This is an unofficial translation of the 2017 Irish Official Standard.
      when "teidealNaCaibidle"
        | Chapter Title
      when "Caibidil"
        | Chapter
      when "Firinscneach"
        | Masculine
      when "Baininscneach"
        | Feminine
      when "FirAgusBain"
        | Masculine and Feminine
      when "Consan"
        | Consonant
      when "Guta"
        | Vowel
      when "urú"
        | eclipsis
      when "séimhiú"
        | lenition
      when "Tábla"
        | Table
      when "Ginearálta"
        | General
      when "Uatha"
        | Singular
      when "Iolra"
        | Plural
      when "Ainmneach"
        | Nominative
      when "Ginideach"
        | Genitive
      when "GachTuiseal"
        | Every Case
      when "Nóta"
        | Note
      when "Inscne"
        | Gender
      when "GanAthrú"
        | No change
      when "saBhrí"
        | meaning
      when "SaBhrí-title"
        | Meaning
      when "nod-u"
        | sg.
      when "nod-iol"
        | pl.
      when "nod-sb"
        | aut.
      when "nó"
        | or
      default
        - throw new Error(`No content for ${key}`)