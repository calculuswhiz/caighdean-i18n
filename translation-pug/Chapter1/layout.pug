include ../bodyMatter.pug
include ./dbs/index.pug
include tables.pug

+chapterTemplate(1)
  +hx(2, "1.1", "1-1-title")
    each val in range(1, 4)
      +hx(3, `1.1.${val}`)
        p: +renderKey(`1-1-${val}-p`)

    +hx(3, "1.1.5")
      p: +renderKey('1-1-5-p')

      ol(class="list-[lower-alpha]")
        li#sec_1_1_5_a
          p: +renderKey("1-1-5-a-p")
          +sampleBox('1-1-5-a-sample', 4)
        li#sec_1_1_5_b
          p: +renderKey("1-1-5-b-p")
          +sampleBox('1-1-5-b-sample', 4)
        li#sec_1_1_5_c
          p: +renderKey("1-1-5-c-p")
          +sampleBox('1-1-5-c-sample', 6)
        li#sec_1_1_5_d
          p: +renderKey("1-1-5-d-p1")
          +sampleBox('1-1-5-d-sample', 3)
          p: +renderKey("1-1-5-d-p2")
        li#sec_1_1_5_e
          p: +renderKey("1-1-5-e-p1")
          +sampleBox('1-1-5-e-sample', 3)
          p: +renderKey("1-1-5-e-p2")
          p: +renderKey("1-1-5-e-p3")
        li#sec_1_1_5_f
          p: +renderKey("1-1-5-f-p1")
          p: +renderKey("1-1-5-f-p2")
          +sampleBox('1-1-5-f-sample', 2)
        li#sec_1_1_5_g
          p: +renderKey("1-1-5-g-p1")
          p: +renderKey("1-1-5-g-p2")
          +sampleBox('1-1-5-g-sample', 5)
          p: +renderKey("1-1-5-g-p3")
        li#sec_1_1_5_h
          p: +renderKey("1-1-5-h-p1")
          ol(class="list-[lower-roman]")
            each val in romanCount(3)
              li(id=`sec_1_1_5_h_${val}`)
                +renderKey(`1-1-5-h-${val}`)
          +sampleBox('1-1-5-h-sample', 3)
        li#sec_1_1_5_i
          p: +renderKey("1-1-5-i-p1")
          ol(class="list-[upper-alpha]")
            li#sec_1_1_5_i_A
              +renderKey("1-1-5-i-A-p1")
              ol(class="list-[lower-roman]")
                each val in romanCount(3)
                  li(id=`sec_1_1_5_i_A_${val}`)
                    +renderKey(`1-1-5-i-A-${val}`)
              +renderKey("1-1-5-i-A-p2")
              +sampleBox('1-1-5-i-A-sample', 2)
            li#sec_1_1_5_i_B
              +renderKey("1-1-5-i-B-p")
              ol(class="list-[lower-roman]")
                each val in romanCount(4)
                  li(id=`sec_1_1_5_i_B_${val}`)
                    +renderKey(`1-1-5-i-B-${val}`)
            li#sec_1_1_5_i_C
              +renderKey("1-1-5-i-C-p")
              +sampleBox('1-1-5-i-C-sample', 2)
        li#sec_1_1_5_j
          p: +renderKey("1-1-5-j-p")
          +sampleBox('1-1-5-j-sample', 3)
        li#sec_1_1_5_k
          p: +renderKey("1-1-5-k-p1")
          p: +renderKey("1-1-5-k-p2")
          +sampleBox('1-1-5-k-sample', 3)
        li#sec_1_1_5_l
          p: +renderKey("1-1-5-l-p1")
          +sampleBox('1-1-5-l-sample', 7)
          p: +renderKey("1-1-5-l-p2")
        li#sec_1_1_5_m
          p: +renderKey("1-1-5-m-p")
          +sampleBox('1-1-5-m-sample', 2)
        li#sec_1_1_5_n
          p: +renderKey("1-1-5-n-p1")
          +sampleBox('1-1-5-n-sample', 3)
          p: +renderKey("1-1-5-n-p2")
  hr

  +hx(2, "1.gp2-5", "h2-gp-2-5-title")
    p: +renderKey("h2-gp-2-5-p")

    +hx(3, "1.2", "1-2-title")
      +renderKey("1-2-p1")
      +Table1A
      +renderKey('LenitionNote')
    hr

    +hx(3, "1.3", "1-3-title")
      each val in range(1, 3)
        +hx(4, `1.3.${val}`)
          p: +renderKey(`1-3-${val}-p`)

      +hx(4, "1.3.4")
        p: +renderKey('1-3-4-p')
        table
          colgroup
            col(class="w-2/5")
            col(class="w-1/5")
          tbody
            tr
              td de + an
              td &rarr;
              td den
            tr
              td do + an
              td &rarr;
              td don
            tr
              td faoi + an
              td &rarr;
              td faoin
            tr
              td i + an
              td &rarr;
              td sa, san
            tr
              td ó + an
              td &rarr;
              td ón
      hr

      +hx(4, "1.3.5")
        p: +renderKey('1-3-5-p')
        table
          colgroup
            col(class="w-2/5")
            col(class="w-1/5")
          tbody
            tr
              td fara + an
              td &rarr;
              td fairis an
            tr
              td le + an
              td &rarr;
              td leis an
            tr
              td trí + an
              td &rarr;
              td tríd an
      hr

      +hx(3, "1.4", "1-4-title")
        +hx(4, "1.4.1")
          p: +renderKey('1-4-1-p')
          +Table1B

        +hx(4, "1.4.2")
          p: +renderKey('1-4-2-p')
          +Table1C

        +hx(4, "1.4.3")
          p: +renderKey('1-4-3-p')
          +Table1D

        +hx(4, "1.4.4")
          p: +renderKey('1-4-4-p')
          +Table1E
          b N.B.
          aside
            p: +renderKey('1-4-4-NB-p1')
            ol(class="list-[lower-alpha]")
              li: +renderKey('1-4-4-NB-a')
              li: +renderKey('1-4-4-NB-b')
      hr

      +hx(3, "1.5", "1-5-title")
        +hx(4, "1.5.1")
          p: +renderKey('1-5-1-p1')
          ol(class="list-[lower-alpha]")
            li#sec_1_5_1_a
              p: +renderKey('1-5-1-a-p')
              +sampleBox('1-5-1-a-sample', 2)
            li#sec_1_5_1_b
              p: +renderKey('1-5-1-b-p')
              +sampleBox('1-5-1-b-sample', 2)
            li#sec_1_5_1_c
              p: +renderKey('1-5-1-c-p')
              +sampleBox('1-5-1-c-sample', 2)
            li#sec_1_5_1_d
              p: +renderKey('1-5-1-d-p')
              +sampleBox('1-5-1-d-sample', 2)
            li#sec_1_5_1_e
              p: +renderKey('1-5-1-e-p')
              +sampleBox('1-5-1-e-sample', 2)
          p: +renderKey('1-5-1-p2')

        +hx(4, "1.5.2")
          p: +renderKey('1-5-2-p')
          +Table1F
          p: +renderKey('LenitionNote')
      hr
    //- This is the end of the group of sections 1.2 - 1.5

  +hx(2, "1.6", "1-6-title")
    +renderKey("1-6-p")

    +hx(3, "1.6.1", "1-6-1-title")
        p: +renderKey("1-6-1-p1")
        +Table1G

    +hx(3, "1.6.2", "1-6-2-title")
        p: +renderKey("1-6-2-p1")
        +Table1H

    +hx(3, "1.6.3", "1-6-3-title")
        p: +renderKey("1-6-3-p")
        +Table1I
        +renderKey('EclipsisNote')
  hr

  +hx(2, "1.7", "1-7-title")
    +hx(3, "1.7.1")
      p: +renderKey('1-7-1-p')
    
    +hx(3, "1.7.2")
      p: +renderKey('1-7-2-p')

    +hx(3, "1.7.3")
      p: +renderKey('1-7-3-p')
      +Table1J

    +hx(3, "1.7.4")
      p: +renderKey('1-7-4-p')
      +Table1K

    +hx(3, "1.7.5")
      p: +renderKey('1-7-5-p')
      +Table1L

    +hx(3, "1.7.6")
      p: +renderKey('1-7-6-p')
      +Table1M
  hr
