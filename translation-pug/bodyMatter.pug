//- Colleciton of mixins to help with generating chapter layout
//- Make sure you only include this ONCE in the layout file

-
  // JS helper functions

  // No, generators are not allowed, I checked.
  // start - end inclusive
  function range(start, end, step = 1) {
    const result = [];
    for (let i = start; i <= end; i += step) 
      result.push(i);

    return result;
  }

  const romanMap = {
    1: 'i',
    2: 'ii',
    3: 'iii',
    4: 'iv',
    5: 'v',
    6: 'vi',
    7: 'vii',
    8: 'viii',
    9: 'ix',
    10: 'x'
  };

  function romanCount(num) {
    return range(1, num).map(n => romanMap[n]);
  }

  const alphabet = 'abcdefghijklmnopqrstuvwxyz';
  function alphaRange(endLetter, uppercase = false) {
    const endIndex = alphabet.indexOf(endLetter.toLowerCase());
    if (endIndex === -1)
      throw new Error(`Invalid end letter: ${endLetter}`);

    const letters = alphabet.slice(0, endIndex + 1);
    return uppercase ? letters.toUpperCase() : letters;
  }

//- Mixins

//- Given array of ratios, auto-size them to fit 100% width
mixin autoColgroup(ratios)
  colgroup
    each ratio in ratios
      col(style=`width: ${ratio / ratios.reduce((a, b) => a + b, 0) * 100}%`)

mixin commonTemplate(titleKey)
  html
    head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title: +renderKey(titleKey)
    link(rel="stylesheet" href="/src/index-pug.css")
  body
    header
      #home-menu-container
        a#menu-link(href="../")
    #toc-container
    block
    //- TODO Translate script
    //- script(type="module" src="/src/chapterScripts.ts")

mixin chapterTemplate(chapterNum)
  +commonTemplate(`${chapterNum}-title`)
    +hx(1, chapterNum.toString(), `${chapterNum}-title`)
      block

//- 
  Retrieve key from db.
  If getFromGa is true, get from gaDb regardless of docLang.
  Otherwise, just get from expected language db.
mixin renderKey(key, options = { getFromGa: false, getFromCommon: false })
  -
    const getFromGa = options.getFromGa ?? false;
    const getFromCommon = options.getFromCommon ?? false;

  if docLang === 'GA' || getFromGa
    if getFromCommon
      +commonGaDb(key)
    else
      +gaDb(key)
  else
    if getFromCommon
      +commonTlDb(key)
    else
      //- - console.log(docLang, options);
      +tlDb(key)

//- 
  Sampleboxes for example sentences. If the document is not in Irish, the Irish version of the sentence is also included in the box for reference.
  - samplePrefix is the prefix for the keys to retrieve (e.g. "8-1-1-sample")
  - sampleCount is the number of sentences to include
  - startAt is the number to start at (default 1)
    This is useful if you have samples interrupted by other content
mixin sampleBox(samplePrefix, sampleCount, startAt = 1)
  table.samplebox(class="my-1")
    tbody
      each row in range(startAt, startAt + sampleCount - 1)
        tr
          if docLang === 'GA'
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              +renderKey(`${samplePrefix}${row}`)
          else
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              +renderKey(`${samplePrefix}${row}`, { getFromGa: true })
            td(class="bg-stone-100 border-1 border-[rgba(0,0,0,0.1)] p-1")
              +renderKey(`${samplePrefix}${row}`)

//- 
  Normal chapter content table (e.g. Table 1A)
  Puts in a caption too.
mixin markedTable(chapter, tableLetter, captionKey)
  table(
    class=`chapter-${chapter}`
    id=`table${chapter}${tableLetter}`
  )&attributes(attributes)
    caption
      b(class="pr-2")
        +renderKey('Tábla', { getFromCommon: true })
        | &nbsp;#{chapter}#{tableLetter}
      +renderKey(captionKey)
    block

//- 
  Generates heading element. Comes with id, anchor link
  - The id is formatted as as sec_ + nav with dots replaced by underscores
  If normal nav string is provided (1.2.3, etc.), 
    - the nav is displayed before the title text
  In the case where the nav contains .gp$x-$y
    - do not display nav before title text
mixin hx(level, nav, titleKey = null)
  -
    if (level < 1 || level > 5)
      throw new Error(`Unsupported heading level: ${level}`);

    const id = `sec_${nav.replace(/\./g, '_')}`;
    const tag = `h${level}`;

  //- Main tag
  #{tag}(id=id)
    //- Anchor link
    a(
      href=`#${id}`, 
      class="mx-2 text-blue-400 hover:text-blue-600 cursor-pointer select-none"
    ) #
    if (level > 1 && !nav.includes('.gp'))
      span(class="mr-2") #{nav}
    if titleKey != null
      +renderKey(titleKey)
  if level === 1
    //- H1 reserved for chapter, so border just adds noise
    main
      block
  else
    section(class="pl-1 border-l-3 border-gray-200")
      block
